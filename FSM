   def action_place(self):
      self.get_logger().info('Opening gripper to drop target...')
      # 
      self._send_joint_goal_async(
         GROUP_NAME_GRIPPER, GRIPPER_JOINT_NAMES, [GRIPPER_OPEN], self._step_place_done
      )

