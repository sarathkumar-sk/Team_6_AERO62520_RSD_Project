   #FSM Spin
   def fsm_spin(self):
      """
      
      """
      event = self.check_transition_condition()
      #if FSM event is obtained
      #then start state transition
      if event is not None:
         self.transition(event)

   #State Transition
   def transition(self, event: FSMEvent):
      """Based on Event and Current State, execute Transition"""
      key = (self.current_state, event)
      next_state = FSM_TRANSITION_TABLE.get(key)

      if next_state is None:

         return

      self.get_logger().info(f'State Transition: [{self.current_state.name}] -- ({event.name}) --> [{next_state.name}]')

      self.previous_state = self.current_state
      self.current_state = next_state

      #Publish Current State
      msg = String()
      msg.data = self.current_state.name
      self.state_pub.publish(msg)

      #Execute entry action to new state
      self.execute_state_action(self.current_state)

