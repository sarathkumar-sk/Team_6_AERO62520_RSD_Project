      if target:
         x, y, z = target.position.x, target.position.y, target.position.z
         self._move_to_pose_async(x, y, z + LIFT_Z_OFFSET, "lift", self._step_go_home_after_lift)

   def _step_go_home_after_lift(self):
      # After lifting the target, reset the arm to home position to prepare for navigation back to start and bin detection
      self._send_joint_goal_async(GROUP_NAME_ARM, ARM_JOINT_NAMES, HOME_JOINTS)

