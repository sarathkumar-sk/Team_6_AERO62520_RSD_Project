#FSM States
class RobotState(Enum):
   INITILIZATION = auto()           #INITILIZATION
   MAPPING_LOCALIZATION = auto()    #SLAM
   EXPLORATION_DETECTION = auto()   #Nav2 + YOLO + RGB-D
   APPROACH = auto()                #Nav2
   ARM_APPROACH_1 = auto()          #MoveIt2
   GRASP = auto()                   #MoveIt2
   ARM_APPROACH_2 = auto()          #MoveIt2
   RETURN = auto()                  #Nav2
   BIN_DETECTION = auto()           #YOLO
   ARM_APPROACH_3 = auto()          #MoveIt2
   PLACE = auto()                   #MoveIt2
   ARM_APPROACH_4 = auto()          #MoveIt2
   MISSION_COMPLETE = auto()                         

#FSM Transition Events
class FSMEvent(Enum):
   ALL_HARDWARE_READY = auto()      # All hardware components (Nav2, MoveIt2, YOLO, Gripper, etc.) are ready for operation 
   MAP_BUILT = auto()               # SLAM map is built and robot is localized
   TARGET_DETECTED = auto()         # YOLO detects the target and provides the target pose
   ARRIVE_AT_TARGET = auto()        # Nav2 reaches the target position
   REACH_DESIGNATED_POSE = auto()   # Used for multiple transitions where the robot arm reaches a designated pose for grasping or placing
   TARGET_IN_GRIPPER = auto()       # Used for multiple transitions where the target is successfully grasped and held in the gripper
   TARGET_NOT_IN_GRIPPER = auto()   # Used for multiple transitions where the target is lost or not successfully grasped
   ARM_RESET = auto()               # Arm reset to predefined pose after grasping or placing
   ARRIVE_AT_START = auto()         # Arrive at the starting position for bin detection
   BIN_FOUND = auto()               # Bin detected in the starting location
   TARGET_PLACED = auto()           # Target placed in bin, check if more targets need to be picked and placed
   ALL_TARGETS_PLACED = auto()      # All targets are placed in the bin, mission complete  

#FSM Transition Table
FSM_TRANSITION_TABLE = {

   #Initialization -> Mapping+Localization
   (RobotState.INITILIZATION,    FSMEvent.ALL_HARDWARE_READY):    RobotState.MAPPING_LOCALIZATION,

   #Mapping+Localization -> Exploration & Object Detection
   (RobotState.MAPPING_LOCALIZATION,    FSMEvent.MAP_BUILT):    RobotState.EXPLORATION_DETECTION,

   #Exploration & Object Detection -> Approach
   (RobotState.EXPLORATION_DETECTION,    FSMEvent.TARGET_DETECTED):    RobotState.APPROACH,

   #Approach -> Arm Approach 1
   (RobotState.APPROACH,    FSMEvent.ARRIVE_AT_TARGET):    RobotState.ARM_APPROACH_1,

   #Arm Approach 1 -> Grasp
   (RobotState.ARM_APPROACH_1,   FSMEvent.REACH_DESIGNATED_POSE):    RobotState.GRASP,

   #Grasp -> Arm Approach 2
   (RobotState.GRASP,    FSMEvent.TARGET_IN_GRIPPER):    RobotState.ARM_APPROACH_2,
   #Grasp -> Exploration & Object Detection
   (RobotState.GRASP,    FSMEvent.TARGET_NOT_IN_GRIPPER):    RobotState.EXPLORATION_DETECTION,

   #Arm Approach 2 -> Return
   (RobotState.ARM_APPROACH_2,    FSMEvent.ARM_RESET):    RobotState.RETURN,
   #Arm Approach 2 -> Exploration & Object Detection
   (RobotState.ARM_APPROACH_2,    FSMEvent.TARGET_NOT_IN_GRIPPER):    RobotState.EXPLORATION_DETECTION,

   #Retrun -> Bin Detection
   (RobotState.RETURN,    FSMEvent.ARRIVE_AT_START):    RobotState.BIN_DETECTION,
   #Retrun -> Exploration & Object Detection
   (RobotState.RETURN,    FSMEvent.TARGET_NOT_IN_GRIPPER):    RobotState.EXPLORATION_DETECTION,

   #Bin Detection -> Arm Approach 3
   (RobotState.BIN_DETECTION,    FSMEvent.BIN_FOUND):    RobotState.ARM_APPROACH_3,
   #Bin Detection -> Exploration & Object Detection
   (RobotState.BIN_DETECTION,    FSMEvent.TARGET_NOT_IN_GRIPPER):    RobotState.EXPLORATION_DETECTION,

   #Arm Approach 3 -> Place
   (RobotState.ARM_APPROACH_3,    FSMEvent.REACH_DESIGNATED_POSE):    RobotState.PLACE,
   #Arm Approach 3 -> Exploration & Object Detection
   (RobotState.ARM_APPROACH_3,    FSMEvent.TARGET_NOT_IN_GRIPPER):    RobotState.EXPLORATION_DETECTION,

   #Place -> Arm Approach 4
   (RobotState.PLACE,    FSMEvent.TARGET_PLACED):    RobotState.ARM_APPROACH_4,
   #Place -> Mission Complete
   (RobotState.PLACE,    FSMEvent.ALL_TARGETS_PLACED):    RobotState.MISSION_COMPLETE,

   #Arm Approach 4 -> Exploration & Object Detection
   (RobotState.ARM_APPROACH_4,    FSMEvent.ARM_RESET):    RobotState.EXPLORATION_DETECTION,

}

