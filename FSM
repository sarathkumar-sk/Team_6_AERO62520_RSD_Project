   #[ARM_APPROACH_1] action: 
   def action_arm_approach_1(self):
      self.get_logger().info('Approaching target (Pre-grasp)...')
      self._send_joint_goal_async(GROUP_NAME_GRIPPER, GRIPPER_JOINT_NAMES, [GRIPPER_OPEN], self._step_pre_grasp)

   def _step_pre_grasp(self):
      target = self._get_pose_in_base(self.target_pose)
      if target:
         x, y, z = target.position.x, target.position.y, target.position.z
         self._move_to_pose_async(x, y, z + PRE_GRASP_Z_OFFSET, "pre-grasp", self._step_grasp_descend)

   def _step_grasp_descend(self):
      target = self._get_pose_in_base(self.target_pose)
      if target:
         x, y, z = target.position.x, target.position.y, target.position.z
         # Move to grasp pose, which is directly above the target with a certain offset, and then execute the grasp action in the next step
         self._move_to_pose_async(x, y, z + GRASP_Z_OFFSET, "grasp")
   
   #[GRASP] action
   def action_grasp(self):
