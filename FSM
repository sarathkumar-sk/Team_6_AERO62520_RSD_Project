   #[ARM_APPROACH_3] action
   def action_arm_approach_3(self):
      self.get_logger().info('Hovering above the bin...')
      target = self._get_pose_in_base(self.bin_pose)
      if target:
         bx, by, bz = target.position.x, target.position.y, target.position.z
         
         # Calculate the hover and release positions based on the detected bin pose and predefined offsets
         box_rim_z = bz + BOX_HEIGHT_M
         self.place_hover_z = box_rim_z + SAFE_HOVER_ABOVE_RIM
         self.place_release_z = box_rim_z - RELEASE_BELOW_RIM
         self.place_bx = bx
         self.place_by = by

         # First move to a hover position above the box rim to avoid collision, then in the callback move down to the release position inside the box for placing the target
         self._move_to_pose_async(
            self.place_bx, self.place_by, self.place_hover_z, 
            "hover-above-bin", self._step_lower_to_release
         )

   def _step_lower_to_release(self):
      self.get_logger().info('Lowering into the bin...')
      # After hovering above the bin, move down to the release position inside the bin to prepare for placing the target 
      # Then execute the place action in the next step 
      self._move_to_pose_async(
         self.place_bx, self.place_by, self.place_release_z, "release-point"
      )
   
