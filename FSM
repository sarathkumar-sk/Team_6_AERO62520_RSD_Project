      self.get_logger().info('Target released successfully.')
      self.place_done = True  # Set place done flag to trigger FSM transition, and then in the transition check if more targets need to be picked and placed or mission is complete

   #[ARM_APPROACH_4] action
   def action_arm_approach_4(self):
      self.get_logger().info('Retreating above the bin...')
      # After placing the target in the bin, move the arm back up to a safe hover position above the bin before navigating back to exploration and detection for the next target
      self._move_to_pose_async(
         self.place_bx, self.place_by, self.place_hover_z, 
         "retreat-above-bin", self._step_go_home_after_place
      )

   def _step_go_home_after_place(self):
      self.get_logger().info('Resetting arm to home...')
      # After retreating above the bin, reset the arm to home position to prepare for the next round of exploration, detection, and picking
      self._send_joint_goal_async(GROUP_NAME_ARM, ARM_JOINT_NAMES, HOME_JOINTS)


   # =========================================================
   # MoveIt2 Asynchronous Helpers
   # =========================================================
   def _send_joint_goal_async(self, group_name: str, joint_names: list, positions: list, callback=None):
      goal = MoveGroup.Goal()
      goal.request.group_name = group_name
      con = Constraints()
      for name, pos in zip(joint_names, positions):
         jc = JointConstraint(joint_name=name, position=float(pos),
                              tolerance_above=0.05, tolerance_below=0.05, weight=1.0)
         con.joint_constraints.append(jc)
      goal.request.goal_constraints.append(con)
      
      future = self.moveit_client.send_goal_async(goal)
      if callback:
         future.add_done_callback(lambda f: self._goal_response_callback(f, callback))
      else:
         future.add_done_callback(self.moveit_result_callback)

   def _move_to_pose_async(self, x: float, y: float, z: float, label: str, callback=None):
      flange_z = z + TCP_OFFSET
      goal = MoveGroup.Goal()
      goal.request.group_name = GROUP_NAME_ARM
      
      con = Constraints(name="goal")
      pos = PositionConstraint(link_name=EEF_LINK)
      pos.header.frame_id = BASE_LINK
      
      bv = BoundingVolume()
      prim = SolidPrimitive(type=SolidPrimitive.SPHERE, dimensions=[0.002])
      target_pose = PoseStamped()
      target_pose.pose.position.x = x
      target_pose.pose.position.y = y
      target_pose.pose.position.z = flange_z
      bv.primitives.append(prim)
      bv.primitive_poses.append(target_pose.pose)
      pos.constraint_region = bv

      ori = OrientationConstraint(link_name=EEF_LINK, orientation=DOWN_QUAT,
                                  absolute_x_axis_tolerance=0.1, absolute_y_axis_tolerance=0.1,
                                  absolute_z_axis_tolerance=0.1, weight=1.0)
      ori.header.frame_id = BASE_LINK

      con.position_constraints.append(pos)
      con.orientation_constraints.append(ori)
      goal.request.goal_constraints.append(con)

      future = self.moveit_client.send_goal_async(goal)
      if callback:
         future.add_done_callback(lambda f: self._goal_response_callback(f, callback))
      else:
         future.add_done_callback(self.moveit_result_callback)

   def _goal_response_callback(self, future, success_callback):
      goal_handle = future.result()
      if not goal_handle.accepted:
         self.get_logger().error("MoveIt2 Goal Rejected!")
         return
      res_future = goal_handle.get_result_async()
      res_future.add_done_callback(lambda f: self._action_result_callback(f, success_callback))

   def _action_result_callback(self, future, success_callback):
      result = future.result().result
      if result.error_code.val == MoveItErrorCodes.SUCCESS:
         success_callback()
      else:
         self.get_logger().warn(f"MoveIt2 Execution Failed with code: {result.error_code.val}")

   def _get_pose_in_base(self, map_pose: PoseStamped) -> PoseStamped:
      """Transforms a PoseStamped from 'map' to 'g_base' frame"""
      try:
         t = self.tf_buffer.lookup_transform(BASE_LINK, map_pose.header.frame_id, rclpy.time.Time())
         return tf2_geometry_msgs.do_transform_pose(map_pose.pose, t)
      except Exception as e:
         self.get_logger().warn(f'Transform to {BASE_LINK} failed: {e}')
         return None
   

   #Check Transition Event
   def check_transition_condition(self) -> FSMEvent | None:

      if self.current_state == RobotState.INITILIZATION:
         if self.check_hardware_ready():
            return FSMEvent.ALL_HARDWARE_READY
         
      elif self.current_state == RobotState.MAPPING_LOCALIZATION:
         if self.map_is_ready:
            return FSMEvent.MAP_BUILT
         
      elif self.current_state == RobotState.EXPLORATION_DETECTION:
         if self.target_detected and self.target_pose is not None:
            return FSMEvent.TARGET_DETECTED
         
      elif self.current_state == RobotState.APPROACH:
         if self.check_arrived_at_target():
            return FSMEvent.ARRIVE_AT_TARGET
         
      elif self.current_state == RobotState.ARM_APPROACH_1:
         if self.reach_designated_pose():
            return FSMEvent.REACH_DESIGNATED_POSE
         
      elif self.current_state == RobotState.GRASP:
         if self.target_in_gripper:
            return FSMEvent.TARGET_IN_GRIPPER
         elif self.target_not_in_gripper:
            return FSMEvent.TARGET_NOT_IN_GRIPPER
         
      elif self.current_state == RobotState.ARM_APPROACH_2:
         if self.arm_reset():
            return FSMEvent.ARM_RESET
         elif self.target_not_in_gripper:
            return FSMEvent.TARGET_NOT_IN_GRIPPER
         
      elif self.current_state == RobotState.RETURN:
         if self.check_arrived_at_start():
            return FSMEvent.ARRIVE_AT_START
         elif self.target_not_in_gripper:
            return FSMEvent.TARGET_NOT_IN_GRIPPER
      
      elif self.current_state == RobotState.BIN_DETECTION:
         if self.bin_found and self.bin_pose is not None:
            self.bin_found = False #Reset flag
            return FSMEvent.BIN_FOUND
         elif self.target_not_in_gripper:
            return FSMEvent.TARGET_NOT_IN_GRIPPER
         
      elif self.current_state == RobotState.ARM_APPROACH_3:
         if self.reach_designated_pose():
            return FSMEvent.REACH_DESIGNATED_POSE
         elif self.target_not_in_gripper:
            return FSMEvent.TARGET_NOT_IN_GRIPPER
         
      elif self.current_state == RobotState.PLACE:
         if self.place_done:
            self.place_done = False #Reset flag
            
            # Update completed targets count and pending colors list
            self.completed_targets += 1
            if self.target_color in self.pending_colors:
               self.pending_colors.remove(self.target_color) #Remove completed target color from pending list

            # Check if all targets are completed or no more pending colors
            if self.completed_targets >= 3 or len(self.pending_colors) == 0: #Assuming we have 3 target objects to pick and place, update this condition based on your actual requirements
               self.get_logger().info('All targets completed! Mission accomplished!')
               return FSMEvent.ALL_TARGETS_PLACED
            else:
               return FSMEvent.TARGET_PLACED

      elif self.current_state == RobotState.ARM_APPROACH_4:
         if self.arm_reset():
            return FSMEvent.ARM_RESET
         elif self.target_not_in_gripper:
            return FSMEvent.TARGET_NOT_IN_GRIPPER 

      return None
   
   def check_hardware_ready(self) -> bool:
      '''check if all hardware is ready for operation, including Nav2, MoveIt2, YOLO, Gripper, etc.'''

      #
      #
      #
      return self.map_is_ready
   
   def check_arrived_at_target(self) -> bool:
      ''''check if Nav2 goal is reached, can be implemented by subscribing to Nav2 result topic or using Nav2 action client feedback/result'''

      if self.nav_goal_reached:
         self.nav_goal_reached = False #reset flag
         return True
      return False
   
   def check_arrived_at_start(self) -> bool:
      '''''check if Nav2 goal is reached for returning to start position, can be implemented by subscribing to Nav2 result topic or using Nav2 action client feedback/result'''

      if self.nav_goal_reached:
         self.nav_goal_reached = False #reset flag
         return True
      return False
   
   def reach_designated_pose(self) -> bool:
      '''check if MoveIt2 manipulator reaches the designated pose, can be implemented by subscribing to MoveIt2 result topic or using MoveIt2 action client feedback/result'''

      if self.arm_reached_pose:
         self.arm_reached_pose = False #reset flag
         return True
      return False
   
   def arm_reset(self) -> bool:
      '''check if MoveIt2 manipulator resets to a predefined pose, can be implemented by subscribing to MoveIt2 result topic or using MoveIt2 action client feedback/result'''

      if self.arm_reached_pose:
         self.arm_reached_pose = False #reset flag
         return True
      return False

   # Callbacks for Subscribers and Action Clients

   def slam_callback(self, msg: Bool):
      '''Callback function for SLAM map ready status'''
      
      if msg.data:
         self.get_logger().info('Map is built.')
         self.map_is_ready = True

   def box_pose_callback(self, msg: PoseStamped):
      '''Callback function for YOLO detection result, which provides the bin pose'''

      if self.current_state == RobotState.BIN_DETECTION:

         #Check if current detected box color matches current target color
         if self.latest_box_color == self.target_color:
            
            try:
               # Lookup transform from camera frame to map frame
               t = self.tf_buffer.lookup_transform(
                     'map', 
                     msg.header.frame_id, 
                     msg.header.stamp, 
                     timeout=Duration(seconds=0.5))
               
               # Execute coordinate transformation
               transformed_pose = tf2_geometry_msgs.do_transform_pose(msg.pose, t)
               
               self.bin_pose = PoseStamped()
               self.bin_pose.header.frame_id = 'map'
               self.bin_pose.pose = transformed_pose
               
               self.bin_found = True #Set bin found flag
            except Exception as e:
               self.get_logger().warn(f'Failed to transform box pose: {e}')
            
   def box_color_callback(self, msg: String):
      '''Callback function for YOLO detection result, which provides the detected box color'''

      self.latest_box_color = msg.data.lower() #Store the latest detected box color, convert to lowercase for easier comparison


   def cube_pose_callback(self, msg: PoseStamped):
      '''Callback function for YOLO detection result, which provides the target pose'''

      if self.current_state == RobotState.EXPLORATION_DETECTION:

         if self.latest_cube_color in self.pending_colors: #Check if the detected cube color is in the pending colors list

            try:
               # Lookup transform from camera frame to map frame
               t = self.tf_buffer.lookup_transform(
                     'map', 
                     msg.header.frame_id, 
                     msg.header.stamp, 
                     timeout=Duration(seconds=0.5))
               
               # 执行坐标转换
               transformed_pose = tf2_geometry_msgs.do_transform_pose(msg.pose, t)
               
               self.target_pose = PoseStamped()
               self.target_pose.header.frame_id = 'map'
               self.target_pose.pose = transformed_pose
               self.target_color = self.latest_cube_color
               
               self.target_detected = True
            except Exception as e:
               self.get_logger().warn(f'Failed to transform cube pose: {e}')

   def cube_color_callback(self, msg: String):
      '''Callback function for YOLO detection result, which provides the detected target cube color'''

      self.latest_cube_color = msg.data.lower() #Store the latest detected cube color, convert to lowercase for easier comparison

   def nav_result_callback(self, future):
      '''Callback function for Nav2 action result'''
   
      result = future.result().result
      status = future.result().status

      if status == 4: #SUCCEEDED
         self.get_logger().info('Nav2 goal reached.')
         self.nav_goal_reached = True #Set Nav2 goal reached flag
      else:
         self.get_logger().warn('Failed to reach Nav2 goal.')

   def moveit_result_callback(self, future):
      '''Callback function for MoveIt2 action result'''
   
      result = future.result().result

      if result.error_code.val == MoveItErrorCodes.SUCCESS:
         self.get_logger().info('MoveIt2 reached the designated pose.')
         self.arm_reached_pose = True #Set Arm reached pose flag
      else:
         self.get_logger().warn('Failed to reach the designated pose with MoveIt2.')

   def gripper_callback(self, msg: Bool):
      '''Callback function for gripper object detection'''
      
      # Object detected in gripper
      if msg.data:
         if not self.target_in_gripper: #Only log when the state changes to avoid spamming logs
            self.get_logger().info('Object detected in gripper.')
         self.target_in_gripper = True #Set target in gripper flag
         self.target_not_in_gripper = False #Reset target not in gripper flag
      
      # No object detected in gripper
      else:
         if not self.target_not_in_gripper: #Only log when the state changes to avoid
            self.get_logger().info('No object detected in gripper.')
         self.target_in_gripper = False
         self.target_not_in_gripper = True

         # If place 
         if self.current_state == RobotState.PLACE:
            self.get_logger().info('Object placed successfully!')
            self.place_done = True #Set place done flag


def main(args=None):
   rclpy.init(args=args)
   node = RobotFSM()
   try:
      rclpy.spin(node)
   except KeyboardInterrupt:
      pass
   finally:
      node.destroy_node()
      rclpy.shutdown()

if __name__ == '__main__':
   main()
